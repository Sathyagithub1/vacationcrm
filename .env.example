# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/holiday_delight_crm"

# Redis
REDIS_URL="redis://localhost:6379"

# Auth
NEXTAUTH_SECRET="your-secret-key-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# Super Admin (first-time setup)
SUPER_ADMIN_EMAIL="admin@holidaydelight.com"
SUPER_ADMIN_PASSWORD="change-me-immediately"

# SMTP
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""

# SMS Gateway
SMS_API_KEY=""
SMS_API_URL=""

# WhatsApp
WHATSAPP_API_KEY=""
WHATSAPP_API_URL=""

# Backup
BACKUP_CRON="0 2 * * *"

# AI Provider Encryption (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=your_64_hex_char_encryption_key_here

# Tenant credential encryption key — used by src/lib/crypto/credential-encryption.ts
# to encrypt razorpayKeySecret, razorpayWebhookSecret, telephonyApiSecret,
# sttApiKey, and ttsApiKey at rest.  Must be a 32-byte (64 hex char) key.
# Generate: openssl rand -hex 32
#       OR: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# REQUIRED in production — leave blank to disable encryption (dev only).
CREDENTIAL_ENCRYPTION_KEY=

# Phase 6a — gate the new intake pipeline per tenant (comma-separated tenant IDs, or '*' for all)
INTAKE_PIPELINE_V2_ENABLED=
